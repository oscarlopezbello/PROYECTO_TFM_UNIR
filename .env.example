# =============================================================
# Variables de entorno para TFM Match
# Copia este archivo como .env y completa los valores reales.
# =============================================================

# API Key de OpenAI (requerida para embeddings y orquestación LLM)
OPENAI_API_KEY=<tu-api-key-de-openai>

# URL de conexión a MySQL (formato SQLAlchemy)
MYSQL_URL=mysql+pymysql://usuario:contraseña@localhost:3306/analytics_db

# Directorio donde se almacenan las colecciones de ChromaDB
# Puede ser ruta relativa al proyecto o absoluta
CHROMA_DIR=./data/chroma
